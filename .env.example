# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored so real secrets never get committed.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB connection string.
#   Local mongod : mongodb://127.0.0.1:27017/turuq
#   Atlas (SRV)  : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/turuq?retryWrites=true&w=majority
#   Atlas (std)  : mongodb://<user>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/turuq?ssl=true&replicaSet=<rs>&authSource=admin&retryWrites=true&w=majority
#
# Note: the SRV form (mongodb+srv://) needs DNS SRV *and* TXT lookups. If your
# network/ISP blocks DNS TXT queries you'll get "queryTxt ETIMEOUT" — use the
# standard (std) seed-list form above instead, which needs no TXT lookup.
MONGODB_URI=

# JWT settings (used by the authentication feature)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
