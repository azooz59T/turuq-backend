# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
# `.env` is git-ignored so real secrets never get committed.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB connection string.
#   Local mongod : mongodb://127.0.0.1:27017/turuq
#   MongoDB Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/turuq?retryWrites=true&w=majority
MONGODB_URI=

# JWT settings (used by the authentication feature)
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
